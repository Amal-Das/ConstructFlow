@page "/inventory"
@attribute [Authorize]

<PageTitle>Inventory - ConstructFlow</PageTitle>

<div class="page-container">
    <div class="page-header-row">
        <div>
            <h1>Inventory</h1>
            <p class="text-muted">Track material stock across projects</p>
        </div>
        <button class="btn-primary btn-sm" @onclick="GoToCreate">+ New Item</button>
    </div>

    <div class="form-group filter-group">
        <label>Filter by Project</label>
        <select class="form-control" @bind="selectedProjectId" @bind:after="LoadInventory">
            <option value="0">-- Select a project --</option>
            @foreach (var project in projects)
            {
                <option value="@project.Id">@project.Name (@project.Code)</option>
            }
        </select>
    </div>

    @if (selectedProjectId == 0)
    {
        <p class="text-muted">Select a project to view its inventory.</p>
    }
    else if (isLoading)
    {
        <p class="text-muted">Loading inventory...</p>
    }
    else if (items.Count == 0)
    {
        <div class="empty-state">
            <p>No inventory items for this project yet.</p>
            <button class="btn-primary btn-sm" @onclick="GoToCreate">Add your first item</button>
        </div>
    }
    else
    {
        <div class="table-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Unit</th>
                        <th>In Stock</th>
                        <th>Min Level</th>
                        <th>Unit Cost</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td class="cell-bold">@item.ItemName</td>
                            <td>@item.Unit</td>
                            <td class="cell-mono">@item.QuantityInStock</td>
                            <td class="cell-mono text-muted">@item.MinimumStockLevel</td>
                            <td class="cell-mono">@item.UnitCost.ToString("C0")</td>
                            <td>
                                @if (item.IsLowStock)
                                {
                                    <span class="badge badge-warning">Low Stock</span>
                                }
                                else
                                {
                                    <span class="badge badge-success">OK</span>
                                }
                            </td>
                            <td class="cell-actions">
                                <button class="btn-link" @onclick="() => OpenTransactionForm(item)">Record Transaction</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (transactionItem is not null)
{
    <div class="modal-backdrop" @onclick="CloseTransactionForm">
        <div class="modal-card" @onclick:stopPropagation="true">
            <h3>Record Transaction — @transactionItem.ItemName</h3>

            <div class="form-group">
                <label>Transaction Type</label>
                <select class="form-control" @bind="transactionType">
                    <option value="StockIn">Stock In</option>
                    <option value="StockOut">Stock Out</option>
                    <option value="Adjustment">Adjustment (set absolute value)</option>
                </select>
            </div>

            <div class="form-group">
                <label>Quantity</label>
                <input type="number" class="form-control" @bind="transactionQuantity" placeholder="0" />
            </div>

            <div class="form-group">
                <label>Reference (optional)</label>
                <input class="form-control" @bind="transactionReference" placeholder="e.g. PO-2026-014" />
            </div>

            @if (!string.IsNullOrEmpty(transactionError))
            {
                <div class="alert-error">@transactionError</div>
            }

            <div class="form-actions">
                <button class="btn-secondary" @onclick="CloseTransactionForm">Cancel</button>
                <button class="btn-primary btn-sm" @onclick="SubmitTransaction" disabled="@isSubmittingTransaction">
                    @(isSubmittingTransaction ? "Saving..." : "Save")
                </button>
            </div>
        </div>
    </div>
}