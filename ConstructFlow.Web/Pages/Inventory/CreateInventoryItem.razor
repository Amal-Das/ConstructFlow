@page "/inventory/create"
@attribute [Authorize]

<PageTitle>New Inventory Item - ConstructFlow</PageTitle>

<div class="page-container">
    <div class="page-header">
        <h1>New Inventory Item</h1>
        <p class="text-muted">Add a material to track for a project</p>
    </div>

    <div class="form-card">
        <EditForm Model="@model" OnValidSubmit="HandleCreate">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-error">@errorMessage</div>
            }

            <div class="form-group">
                <label>Project</label>
                <InputSelect @bind-Value="model.ProjectId" class="form-control">
                    <option value="0">-- Select a project --</option>
                    @foreach (var project in projects)
                    {
                        <option value="@project.Id">@project.Name (@project.Code)</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => model.ProjectId)" />
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Item Name</label>
                    <InputText @bind-Value="model.ItemName" class="form-control" placeholder="e.g. Portland Cement" />
                    <ValidationMessage For="@(() => model.ItemName)" />
                </div>

                <div class="form-group">
                    <label>Unit</label>
                    <InputText @bind-Value="model.Unit" class="form-control" placeholder="e.g. Bags, Tons, Pieces" />
                    <ValidationMessage For="@(() => model.Unit)" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Minimum Stock Level</label>
                    <InputNumber @bind-Value="model.MinimumStockLevel" class="form-control" placeholder="0" />
                    <ValidationMessage For="@(() => model.MinimumStockLevel)" />
                </div>

                <div class="form-group">
                    <label>Unit Cost (₹)</label>
                    <InputNumber @bind-Value="model.UnitCost" class="form-control" placeholder="0" />
                    <ValidationMessage For="@(() => model.UnitCost)" />
                </div>
            </div>

            <div class="form-actions">
                <button type="button" class="btn-secondary" @onclick="GoBack">Cancel</button>
                <button type="submit" class="btn-primary btn-sm" disabled="@isSubmitting">
                    @(isSubmitting ? "Creating..." : "Create Item")
                </button>
            </div>
        </EditForm>
    </div>
</div>